                                                            "last_name": {
                                                                 "type": "string"
                                                            },
                                                            "email": {
                                                                 "type": "string",
                                                                 "format": "email"
                                                            },
                                                            "password": {
                                                                 "type": "string",
                                                                 "format": "color"
                                                            }
                                                       }
                                                  }
                                             }
                                        },
                                        "example": {
                                             "message": "Usuario creado",
                                             "usuario": {
                                                  "id": "60ab91445334918684501991",
                                                  "first_name": "Diego",
