                                        "example": "Express"
                                   },
                                   "Content-Length": {
                                        "schema": {
                                             "type": "integer"
                                        },
                                        "example": "160"
                                   },
                                   "ETag": {
                                        "schema": {
                                             "type": "string"
                                        },
                                        "example": "W/\"a0-5TjNPZZFgHC/sTZi1b2gf8NhAu4\""
